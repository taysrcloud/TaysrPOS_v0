generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
  USER
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ProductType {
  RETAIL
  MENU_ITEM
  INGREDIENT
  SERVICE
  BUNDLE
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RETURN
}

enum CashMovementType {
  IN
  OUT
}

enum SaleChannel {
  RETAIL
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum SaleStatus {
  DRAFT
  SUSPENDED
  KITCHEN
  READY
  FINAL
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHEQUE
  CREDIT
  MIXED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum RestaurantOrderStatus {
  RECEIVED
  PREPARING
  READY
  SERVED
  CANCELLED
}

model Company {
  id                Int      @id @default(autoincrement())
  accountId         String?  @unique
  name              String
  legalName         String?
  email             String?
  phone             String?
  address           String?
  city              String?
  logoUrl           String?
  ice               String?
  ifNumber          String?
  rc                String?
  patente           String?
  cnss              String?
  defaultCurrency   String   @default("MAD")
  defaultTvaRate    Decimal  @default(20) @db.Decimal(5, 2)
  receiptFooter     String?
  posEnabled        Boolean  @default(true)
  restaurantEnabled Boolean  @default(false)
  invoiceEnabled    Boolean  @default(false)
  opticEnabled      Boolean  @default(false)
  multiWarehouse    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users            User[]
  locations        Location[]
  contacts         Contact[]
  categories       Category[]
  brands           Brand[]
  units            Unit[]
  products         Product[]
  warehouses       Warehouse[]
  sales            Sale[]
  purchases        Purchase[]
  cashSessions     CashRegisterSession[]
  restaurantAreas  RestaurantArea[]
  restaurantTables RestaurantTable[]
  modifierGroups   ModifierGroup[]
  expenses         Expense[]
  cashMovements    CashMovement[]
  invoices         Invoice[]
}

model User {
  id           Int      @id @default(autoincrement())
  companyId    Int
  username     String
  email        String?
  passwordHash String
  fullName     String
  role         UserRole @default(CASHIER)
  isActive     Boolean  @default(true)
  pinHash      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales        Sale[]                @relation("SaleCashier")
  servedSales  Sale[]                @relation("SaleWaiter")
  cashSessions CashRegisterSession[]

  @@unique([companyId, username])
  @@unique([companyId, email])
}

model Location {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouses    Warehouse[]
  sales         Sale[]
  cashSessions  CashRegisterSession[]
  expenses      Expense[]
  cashMovements CashMovement[]

  @@unique([companyId, name])
}

model Contact {
  id          Int         @id @default(autoincrement())
  companyId   Int
  type        ContactType @default(CUSTOMER)
  fullName    String
  phone       String?
  email       String?
  address     String?
  ice         String?
  ifNumber    String?
  creditLimit Decimal?    @db.Decimal(12, 2)
  balance     Decimal     @default(0) @db.Decimal(12, 2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales     Sale[]
  purchases Purchase[]
  invoices  Invoice[]

  @@index([companyId, type])
}

model Category {
  id        Int     @id @default(autoincrement())
  companyId Int
  name      String
  color     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, name])
}

model Brand {
  id        Int    @id @default(autoincrement())
  companyId Int
  name      String

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, name])
}

model Unit {
  id           Int     @id @default(autoincrement())
  companyId    Int
  name         String
  shortName    String
  allowDecimal Boolean @default(false)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, shortName])
}

model Product {
  id            Int                @id @default(autoincrement())
  companyId     Int
  categoryId    Int?
  brandId       Int?
  unitId        Int?
  sku           String
  barcode       String?
  name          String
  description   String?
  type          ProductType        @default(RETAIL)
  imageUrl      String?
  purchasePrice Decimal            @default(0) @db.Decimal(12, 2)
  salePrice     Decimal            @db.Decimal(12, 2)
  tvaRate       Decimal            @default(20) @db.Decimal(5, 2)
  trackStock    Boolean            @default(true)
  lowStockAlert Decimal            @default(0) @db.Decimal(12, 3)
  isActive      Boolean            @default(true)
  isSellable    Boolean            @default(true)
  isVariable    Boolean            @default(false)
  variationOptions Json?
  variations    ProductVariation[]
  isKitchenItem Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id])
  brand           Brand?           @relation(fields: [brandId], references: [id])
  unit            Unit?            @relation(fields: [unitId], references: [id])
  stocks          ProductStock[]
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  modifierOptions ModifierOption[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, type])
}

model Warehouse {
  id         Int     @id @default(autoincrement())
  companyId  Int
  locationId Int?
  name       String
  isMain     Boolean @default(false)
  isActive   Boolean @default(true)

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location  Location?       @relation(fields: [locationId], references: [id])
  stocks    ProductStock[]
  movements StockMovement[]

  @@unique([companyId, name])
}

model ProductStock {
  id          Int               @id @default(autoincrement())
  productId   Int
  warehouseId Int
  variationId Int?
  variation   ProductVariation? @relation(fields: [variationId], references: [id])
  quantity    Decimal           @default(0) @db.Decimal(12, 3)
  updatedAt   DateTime          @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, variationId])
}

model StockMovement {
  id          Int               @id @default(autoincrement())
  productId   Int
  warehouseId Int
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
}

model RestaurantArea {
  id        Int    @id @default(autoincrement())
  companyId Int
  name      String
  sortOrder Int    @default(0)

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tables  RestaurantTable[]

  @@unique([companyId, name])
}

model RestaurantTable {
  id        Int     @id @default(autoincrement())
  companyId Int
  areaId    Int?
  name      String
  seats     Int     @default(2)
  isActive  Boolean @default(true)

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  area    RestaurantArea? @relation(fields: [areaId], references: [id])
  sales   Sale[]

  @@unique([companyId, name])
}

model ModifierGroup {
  id          Int     @id @default(autoincrement())
  companyId   Int
  name        String
  minSelected Int     @default(0)
  maxSelected Int     @default(1)
  isRequired  Boolean @default(false)
  isActive    Boolean @default(true)

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  options ModifierOption[]
}

model ModifierOption {
  id        Int     @id @default(autoincrement())
  groupId   Int
  productId Int?
  name      String
  price     Decimal @default(0) @db.Decimal(12, 2)
  isActive  Boolean @default(true)

  group             ModifierGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product           Product?           @relation(fields: [productId], references: [id])
  saleItemModifiers SaleItemModifier[]
}

model Sale {
  id            Int           @id @default(autoincrement())
  companyId     Int
  locationId    Int?
  customerId    Int?
  cashierId     Int?
  waiterId      Int?
  tableId       Int?
  channel       SaleChannel   @default(RETAIL)
  status        SaleStatus    @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID)
  invoiceNumber String?
  ticketNumber  String?
  note          String?
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  finalizedAt   DateTime?
  invoiceId     Int?
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location?        @relation(fields: [locationId], references: [id])
  customer Contact?         @relation(fields: [customerId], references: [id])
  cashier  User?            @relation("SaleCashier", fields: [cashierId], references: [id])
  waiter   User?            @relation("SaleWaiter", fields: [waiterId], references: [id])
  table    RestaurantTable? @relation(fields: [tableId], references: [id])
  items    SaleItem[]
  payments Payment[]

  @@index([companyId, channel, status])
}

model SaleItem {
  id            Int                    @id @default(autoincrement())
  saleId        Int
  productId     Int
  variationId   Int?
  variation     ProductVariation?      @relation(fields: [variationId], references: [id])
  quantity      Decimal                @db.Decimal(12, 3)
  unitPrice     Decimal                @db.Decimal(12, 2)
  discount      Decimal                @default(0) @db.Decimal(12, 2)
  tvaRate       Decimal                @default(20) @db.Decimal(5, 2)
  lineTotal     Decimal                @db.Decimal(12, 2)
  kitchenStatus RestaurantOrderStatus?
  notes         String?

  sale      Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product            @relation(fields: [productId], references: [id])
  modifiers SaleItemModifier[]
}

model SaleItemModifier {
  id               Int     @id @default(autoincrement())
  saleItemId       Int
  modifierOptionId Int
  quantity         Decimal @default(1) @db.Decimal(12, 3)
  unitPrice        Decimal @db.Decimal(12, 2)
  lineTotal        Decimal @db.Decimal(12, 2)

  saleItem       SaleItem       @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption @relation(fields: [modifierOptionId], references: [id])
}

model Payment {
  id        Int           @id @default(autoincrement())
  saleId    Int
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  paidAt    DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Purchase {
  id         Int      @id @default(autoincrement())
  companyId  Int
  supplierId Int?
  reference  String?
  subtotal   Decimal  @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal  @default(0) @db.Decimal(12, 2)
  total      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier Contact?       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]
}

model PurchaseItem {
  id         Int     @id @default(autoincrement())
  purchaseId Int
  productId  Int
  quantity   Decimal @db.Decimal(12, 3)
  unitCost   Decimal @db.Decimal(12, 2)
  lineTotal  Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

model CashRegisterSession {
  id           Int       @id @default(autoincrement())
  companyId    Int
  locationId   Int?
  userId       Int
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingCash  Decimal   @default(0) @db.Decimal(12, 2)
  expectedCash Decimal   @default(0) @db.Decimal(12, 2)
  countedCash  Decimal?  @db.Decimal(12, 2)
  difference   Decimal?  @db.Decimal(12, 2)
  notes        String?

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location  Location?      @relation(fields: [locationId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  movements CashMovement[]
}

model Expense {
  id            Int      @id @default(autoincrement())
  companyId     Int
  locationId    Int?
  reference     String?
  category      String
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  note          String?
  paymentMethod String   @default("CASH")
  createdAt     DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])
}

model CashMovement {
  id         Int              @id @default(autoincrement())
  companyId  Int
  locationId Int?
  sessionId  Int?
  type       CashMovementType
  amount     Decimal          @db.Decimal(12, 2)
  note       String?
  createdAt  DateTime         @default(now())

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location?            @relation(fields: [locationId], references: [id])
  session  CashRegisterSession? @relation(fields: [sessionId], references: [id])
}

model Invoice {
  id         Int           @id @default(autoincrement())
  companyId  Int
  number     String        @unique
  customerId Int?
  subtotal   Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal       @default(0) @db.Decimal(12, 2)
  total      Decimal       @default(0) @db.Decimal(12, 2)
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Contact? @relation(fields: [customerId], references: [id])
  sales    Sale[]
}

model ProductVariation {
  id            Int      @id @default(autoincrement())
  productId     Int
  name          String
  attributes    Json?
  sku           String?
  barcode       String?
  purchasePrice Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @db.Decimal(12, 2)
  isActive      Boolean  @default(true)

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks    ProductStock[]
  saleItems SaleItem[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  CANCELLED
}
